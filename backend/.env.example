# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=3000
APP_NAME=AckiMeme
APP_NETWORK=Acki Nacki
# TVM SDK: Target v2.24.20.an (see CHANGELOG for compatibility)
# Contracts: TVM-Solidity-Compiler 0.76.1+ (pragma tvm-solidity >= 0.76.1)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ackimeme
DATABASE_SSL=false

# ─── Acki Nacki Network ──────────────────────────────────────────────────────
# Rate: 1 USDC = 100 SHELL (Accumulator official rate). 1 SHELL ≈ $0.01 USD.
GRAPHQL_URL=https://shellnet.ackinacki.org/graphql
FEE_WALLET=0:YOUR_FEE_WALLET_ADDRESS_HERE
CREATION_FEE_SHELL=300

# ─── Shell Buy via USDC (Accumulator System Integration) ─────────────────────
# The Acki Nacki Accumulator System (ShellAccumulatorRootUSDC) trades
# ECC SHELL (ID=2) for ECC USDC (ID=3) at a fixed rate of 100 SHELL = 1 USDC.
# Our SHELL_BUY_SHELL_PER_USDC MUST match the on-chain rate.
# See: https://dev.ackinacki.com/accumulator-contract-system/overview
ENABLE_SHELL_BUY=false
SHELL_BUY_USDC_ROOT=0:YOUR_USDC_TOKEN_ROOT_ADDRESS
SHELL_BUY_USDC_RECIPIENT=0:YOUR_USDC_ACCUMULATOR_OR_EXCHANGE_WALLET
REDIS_URL=redis://localhost:6379
SHELL_BUY_MIN_USDC=1
SHELL_BUY_SHELL_PER_USDC=100
SHELL_BUY_USDC_DECIMALS=6

# ─── ECC Token IDs (Acki Nacki ecosystem) ────────────────────────────────────
# NACKL = 1 (9 decimals, nano) — Staking & store of value
# SHELL = 2 (9 decimals, nano) — Utility token (gas/fees/payments) — 1 SHELL ≈ $0.01
# USDC  = 3 (6 decimals, micro) — Stablecoin
# Our contracts ONLY accept SHELL (ID=2). V-AM-01 validates this on-chain.
#
# ─── Trade Fee (on-chain, BondingCurve.sol) ───────────────────────────────────
# 1% total fee per buy/sell trade:
#   0.8% → FEE_WALLET (platform revenue)
#   0.2% → locked in BondingCurve contract (burn / out of circulation)
# The FEE_WALLET above is passed as feeRecipient to the BondingCurve at deploy.

# ─── Auth & Security ─────────────────────────────────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_WITH_32_CHARS_OR_MORE
ALLOWED_ORIGINS=http://localhost:3001,https://ackimeme.fun
AUTH_CHALLENGE_TTL_SECONDS=300
SESSION_TTL_HOURS=24

# ─── QR Auth Webhook ─────────────────────────────────────────────────────────
# Required in production (min 32 chars). Protects the QR webhook endpoint.
QR_WEBHOOK_SECRET=YOUR_QR_WEBHOOK_SECRET_WITH_32_CHARS_OR_MORE

# ─── Backend URL (required in production) ────────────────────────────────────
# Set to your public backend URL. On Render, RENDER_EXTERNAL_URL is auto-set.
BACKEND_URL=https://api.ackimeme.fun

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_WALLETS=dev-wallet-local
ADMIN_TOKEN=YOUR_ADMIN_TOKEN_WITH_32_CHARS_OR_MORE

# ─── On-Chain Deploy ─────────────────────────────────────────────────────────
# Aceita secret raw de 32 bytes/64 hex para nacl_sign_keypair_from_secret_key
# ou signer secret completo de 64 bytes/128 hex retornado pelo SDK.
DEPLOYER_SECRET_KEY=YOUR_64_OR_128_CHAR_HEX_DEPLOYER_SECRET_KEY
DEPLOYER_PUBLIC_KEY=YOUR_64_CHAR_HEX_DEPLOYER_PUBLIC_KEY
# Alternativa: JSON com { "public": "...", "secret": "..." }.
DEPLOYER_KEYS_FILE=
# Wallet/multisig financiadora usada para enviar SHELL ECC ao endereço futuro
# antes da mensagem externa de deploy.
DEPLOYER_WALLET_ADDRESS=0:YOUR_DEPLOYER_MULTISIG_ADDRESS
DEPLOYER_PREFUND_SHELL_NANO=10000000000
DEPLOYER_PREFUND_MESSAGE_VALUE_NANO=500000000
TELEGRAM_BOT_USERNAME=ackinacki_bot
DEPLOY_FUNDING_CONFIRM_ATTEMPTS=40
BONDING_CURVE_DEPLOY_CONFIRM_ATTEMPTS=200
ENABLE_ONCHAIN_DEPLOY=false
# Caminho absoluto para o tvmsdk.node compilado conforme Quick Start oficial.
# Necessário para deploy/sync on-chain quando @tvmsdk/lib-node não trouxer o binário.
TVM_SDK_NODE_BINARY=

# ─── IPFS ────────────────────────────────────────────────────────────────────
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_API_KEY=YOUR_PINATA_SECRET_KEY
