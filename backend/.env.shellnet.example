# ─── AckiMeme Backend — Shellnet (Testnet) Configuration ─────────────────────
# Copy this file to .env and fill in the values for shellnet testing.
# After successful testing, switch to mainnet values.

# ─── Core ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_NAME=AckiMeme
APP_NETWORK=Acki Nacki Shellnet

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ackimeme_shellnet
DATABASE_SSL=false

# ─── Acki Nacki Network ─────────────────────────────────────────────────────
# SHELLNET endpoint for testing:
GRAPHQL_URL=https://shellnet.ackinacki.org/graphql
# For MAINNET, switch to:
# GRAPHQL_URL=https://mainnet.ackinacki.org/graphql

# ─── On-Chain Deployment ─────────────────────────────────────────────────────
ENABLE_ONCHAIN_DEPLOY=true
# 64-hex raw secret key (32 bytes) or 128-hex full key (64 bytes)
DEPLOYER_SECRET_KEY=YOUR_64_HEX_DEPLOYER_SECRET
DEPLOYER_WALLET_ADDRESS=0:YOUR_DEPLOYER_WALLET_64_HEX
# Optional: explicit path to tvmsdk.node binary for containerized environments
# TVM_SDK_NODE_BINARY=/app/node_modules/@tvmsdk/lib-node/tvmsdk.node

# ─── Fee & Treasury ──────────────────────────────────────────────────────────
FEE_WALLET=0:YOUR_FEE_WALLET_64_HEX
CREATION_FEE_SHELL=300
MIN_CREATOR_SHELL_BALANCE=1

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=GENERATE_A_RANDOM_64_CHAR_HEX_STRING_HERE
JWT_SECRET=GENERATE_ANOTHER_RANDOM_64_CHAR_HEX_STRING_HERE
QR_WEBHOOK_SECRET=GENERATE_ANOTHER_RANDOM_64_CHAR_HEX_STRING_HERE

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://ackimeme.fun,https://www.ackimeme.fun,http://localhost:3001
BACKEND_URL=https://api.ackimeme.fun

# ─── IPFS / Pinata ──────────────────────────────────────────────────────────
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_API_KEY=YOUR_PINATA_SECRET
# Optional: custom Pinata dedicated gateway
# PINATA_GATEWAY_DOMAIN=your-gateway.mypinata.cloud

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# ─── Session ─────────────────────────────────────────────────────────────────
AUTH_CHALLENGE_TTL_SECONDS=300
SESSION_TTL_HOURS=24

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_WALLETS=0:your_admin_wallet_hex

# ─── Shell Buy (disabled for shellnet — enable on mainnet if needed) ────────
ENABLE_SHELL_BUY=false
# SHELL_BUY_USDC_RECIPIENT=0:accumulator_contract
# SHELL_BUY_USDC_ROOT=0:usdc_root_contract
