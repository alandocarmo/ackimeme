{
  "name": "ackimeme-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:migrate": "tsx src/migrate.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "build": "tsc && node -e \"const fs = require('fs'); fs.mkdirSync('dist/migrations', { recursive: true }); fs.cpSync('src/migrations', 'dist/migrations', { recursive: true }); fs.mkdirSync('dist/abi', { recursive: true }); fs.cpSync('src/abi', 'dist/abi', { recursive: true })\"",
    "start": "node dist/migrate.js && node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "dev:wallet:init": "tsx scripts/dev-wallet.ts init",
    "dev:wallet:sign": "tsx scripts/dev-wallet.ts sign",
    "test:integration": "tsx scripts/test-integration.ts",
    "test:validate": "tsx scripts/validate-schemas-smoke.ts && tsx scripts/launch-pipeline-smoke.ts",
    "generate:keys": "tsx scripts/generate-keys.ts"
  },
  "dependencies": {
    "@ackimeme/shared-types": "file:../shared-types",
    "@tvmsdk/core": "^2.2.0",
    "@tvmsdk/lib-node": "^2.0.1",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nekoton-wasm": "^1.29.0",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.3",
    "typescript": "~5.4.0"
  }
}
