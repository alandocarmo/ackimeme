{
  "name": "ackimeme-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "build": "tsc && node -e \"const fs = require('fs'); fs.mkdirSync('dist/migrations', { recursive: true }); fs.cpSync('src/migrations', 'dist/migrations', { recursive: true }); fs.mkdirSync('dist/abi', { recursive: true }); fs.cpSync('src/abi', 'dist/abi', { recursive: true })\"",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "dev:wallet:init": "node scripts/dev-wallet.js init",
    "dev:wallet:sign": "node scripts/dev-wallet.js sign"
  },
  "dependencies": {
    "@tvmsdk/core": "^2.2.0",
    "@tvmsdk/lib-node": "^2.0.1",
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nekoton-wasm": "^1.29.0",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
